# ═══════════════════════════════════════════
# VIMS Event Networking Platform — Env Vars
# ═══════════════════════════════════════════

# ─── Database (Neon PostgreSQL) ───
DATABASE_URL=postgresql://app_write:PASSWORD@ep-shy-frog-am8fc2il-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DIRECT=postgresql://app_admin:PASSWORD@ep-shy-frog-am8fc2il.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── Authentication ───
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-in-production-min-32-chars

# ─── Email (Resend) ───
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ─── File Storage (Cloudflare R2) ───
R2_ACCOUNT_ID=xxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
R2_BUCKET_NAME=vims-events-media
R2_PUBLIC_URL=https://storage.vims-events.com

# ─── Push Notifications (VAPID) ───
VAPID_PUBLIC_KEY=xxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@vims-enterprise.com

# ─── Monitoring ───
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
BETTER_STACK_SOURCE_TOKEN=xxxxxxxxxxxxx

# ─── Application URLs ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# ─── Server ───
PORT=4000
NODE_ENV=development
