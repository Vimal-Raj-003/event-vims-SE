generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

model SuperAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("super_admins")
}

model Organiser {
  id              String             @id @default(cuid())
  name            String
  organisation    String
  email           String             @unique
  passwordHash    String             @map("password_hash")
  mobile          String
  status          OrganiserStatus    @default(ACTIVE)
  emailVerifiedAt DateTime?          @map("email_verified_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  announcements   Announcement[]
  auditLogs       AuditLog[]
  events          Event[]
  supportTickets  SupportTicket[]
  settings        OrganiserSettings?

  @@map("organisers")
}

model Event {
  id               String                @id @default(cuid())
  organiserId      String                @map("organiser_id")
  slug             String                @unique
  shortHash        String                @unique @map("short_hash")
  name             String
  description      String                @db.VarChar(500)
  startAt          DateTime              @map("start_at")
  endAt            DateTime              @map("end_at")
  venue            String
  venueMapUrl      String?               @map("venue_map_url")
  expectedCount    Int?                  @map("expected_count")
  brandLogoUrl     String?               @map("brand_logo_url")
  brandPrimary     String                @default("#4F46E5") @map("brand_primary")
  brandSecondary   String                @default("#818CF8") @map("brand_secondary")
  bannerUrl        String?               @map("banner_url")
  qrUrl            String?               @map("qr_url")
  status           EventStatus           @default(DRAFT)
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  announcements    Announcement[]
  attendees        Attendee[]
  connections      ConnectionRequest[]
  deletionRequests DataDeletionRequest[]
  fieldConfigs     EventFieldConfig[]
  eventRules       EventRule?
  organiser        Organiser             @relation(fields: [organiserId], references: [id])

  @@index([organiserId])
  @@index([status])
  @@index([startAt])
  @@map("events")
}

model EventFieldConfig {
  id         String  @id @default(cuid())
  eventId    String  @map("event_id")
  fieldKey   String  @map("field_key")
  isRequired Boolean @default(true) @map("is_required")
  isVisible  Boolean @default(true) @map("is_visible")
  event      Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, fieldKey])
  @@map("event_field_config")
}

model EventRule {
  id                        String  @id @default(cuid())
  eventId                   String  @unique @map("event_id")
  maxConnectionsPerAttendee String? @map("max_connections_per_attendee")
  showAddressAfterAccept    Boolean @default(true) @map("show_address_after_accept")
  allowVcardDownload        Boolean @default(true) @map("allow_vcard_download")
  event                     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_rules")
}

model Attendee {
  id                  String              @id @default(cuid())
  eventId             String              @map("event_id")
  firstName           String              @map("first_name")
  lastName            String              @map("last_name")
  email               String
  phone               String
  designation         String
  company             String
  businessType        String              @map("business_type")
  industry            String
  services            Json                @default("[]")
  city                String
  address             String?
  companySize         String?             @map("company_size")
  tags                Json                @default("[]")
  profilePhotoUrl     String?             @map("profile_photo_url")
  companyLogoUrl      String?             @map("company_logo_url")
  registeredAt        DateTime            @default(now()) @map("registered_at")
  lastActiveAt        DateTime            @default(now()) @map("last_active_at")
  isPaused            Boolean             @default(false) @map("is_paused")
  consentGiven        Boolean             @default(false) @map("consent_given")
  consentedAt         DateTime?           @map("consented_at")
  age                 Int?
  sex                 String?
  occupation          String?
  interestedIn        Json                @default("[]") @map("interested_in")
  networkingGoals     Json                @default("[]") @map("networking_goals")
  profileCompleted    Boolean             @default(false) @map("profile_completed")
  profileCompletedAt  DateTime?           @map("profile_completed_at")
  linkedinUrl         String?             @map("linkedin_url")
  websiteUrl          String?             @map("website_url")
  twitterHandle       String?             @map("twitter_handle")
  profileViewCount    Int                 @default(0) @map("profile_view_count")
  cardShareCount      Int                 @default(0) @map("card_share_count")
  qrScanCount         Int                 @default(0) @map("qr_scan_count")
  event               Event               @relation(fields: [eventId], references: [id])
  receivedConnections ConnectionRequest[] @relation("ReceivedConnections")
  sentConnections     ConnectionRequest[] @relation("SentConnections")
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  profileViewsReceived ProfileView[]      @relation("ProfileViewed")
  profileViewsMade     ProfileView[]      @relation("ProfileViewer")
  connectionNotes      ConnectionNote[]
  matchScores          MatchScore[]       @relation("MatchTarget")
  matchScoresAsSource  MatchScore[]       @relation("MatchSource")
  activities           Activity[]

  @@unique([eventId, email])
  @@index([eventId])
  @@index([eventId, businessType])
  @@index([eventId, industry])
  @@index([eventId, city])
  @@index([eventId, companySize])
  @@index([company(ops: raw("gin_trgm_ops"))], map: "idx_att_company_trgm", type: Gin)
  @@index([eventId, businessType, industry, city], map: "idx_att_directory")
  @@index([firstName(ops: raw("gin_trgm_ops"))], map: "idx_att_fname_trgm", type: Gin)
  @@index([services], map: "idx_att_services_gin", type: Gin)
  @@index([tags], map: "idx_att_tags_gin", type: Gin)
  @@map("attendees")
}

model ConnectionRequest {
  id          String           @id @default(cuid())
  eventId     String           @map("event_id")
  senderId    String           @map("sender_id")
  receiverId  String           @map("receiver_id")
  status      ConnectionStatus @default(PENDING)
  message     String?          @db.VarChar(200)
  createdAt   DateTime         @default(now()) @map("created_at")
  respondedAt DateTime?        @map("responded_at")
  event       Event            @relation(fields: [eventId], references: [id])
  receiver    Attendee         @relation("ReceivedConnections", fields: [receiverId], references: [id])
  sender      Attendee         @relation("SentConnections", fields: [senderId], references: [id])

  @@unique([eventId, senderId, receiverId])
  @@index([eventId, receiverId, status])
  @@index([eventId, senderId, status])
  @@index([eventId, status])
  @@map("connection_requests")
}

model Announcement {
  id             String    @id @default(cuid())
  eventId        String    @map("event_id")
  organiserId    String    @map("organiser_id")
  title          String
  body           String    @db.VarChar(500)
  linkUrl        String?   @map("link_url")
  sentAt         DateTime  @default(now()) @map("sent_at")
  recipientCount Int       @default(0) @map("recipient_count")
  openedCount    Int       @default(0) @map("opened_count")
  event          Event     @relation(fields: [eventId], references: [id])
  organiser      Organiser @relation(fields: [organiserId], references: [id])

  @@index([eventId, sentAt])
  @@map("announcements")
}

model AuditLog {
  id         String     @id @default(cuid())
  actorId    String?    @map("actor_id")
  actorRole  String?    @map("actor_role")
  action     String
  entityType String     @map("entity_type")
  entityId   String?    @map("entity_id")
  metadata   Json       @default("{}")
  ip         String?
  userAgent  String?    @map("user_agent")
  createdAt  DateTime   @default(now()) @map("created_at")
  organiser  Organiser? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

model DataDeletionRequest {
  id             String                @id @default(cuid())
  requesterEmail String                @map("requester_email")
  eventId        String?               @map("event_id")
  reason         String?
  status         DeletionRequestStatus @default(PENDING)
  requestedAt    DateTime              @default(now()) @map("requested_at")
  processedAt    DateTime?             @map("processed_at")
  processedBy    String?               @map("processed_by")
  event          Event?                @relation(fields: [eventId], references: [id])

  @@index([status])
  @@index([requesterEmail])
  @@map("data_deletion_requests")
}

model OtpVerification {
  id        String    @id @default(cuid())
  email     String
  otpHash   String    @map("otp_hash")
  purpose   String
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email, purpose, expiresAt])
  @@map("otp_verifications")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  userRole  String    @map("user_role")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, userRole])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model PushSubscription {
  id         String   @id @default(cuid())
  attendeeId String   @map("attendee_id")
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now()) @map("created_at")
  attendee   Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@index([attendeeId])
  @@map("push_subscriptions")
}

model Notification {
  id              String   @id @default(cuid())
  attendeeId      String   @map("attendee_id")
  eventType       String   @map("event_type")
  title           String
  body            String
  isRead          Boolean  @default(false) @map("is_read")
  relatedEntityId String?  @map("related_entity_id")
  createdAt       DateTime @default(now()) @map("created_at")
  attendee        Attendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@index([attendeeId, isRead])
  @@index([attendeeId, createdAt])
  @@map("notifications")
}

model SupportTicket {
  id          String         @id @default(cuid())
  organiserId String         @map("organiser_id")
  subject     String
  description String         @db.VarChar(1000)
  category    TicketCategory
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  adminNote   String?        @map("admin_note")
  resolvedAt  DateTime?      @map("resolved_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  organiser   Organiser      @relation(fields: [organiserId], references: [id])

  @@index([organiserId])
  @@index([status])
  @@map("support_tickets")
}

model OrganiserSettings {
  id                         String    @id @default(cuid())
  organiserId                String    @unique @map("organiser_id")
  defaultBrandPrimary        String    @default("#4F46E5") @map("default_brand_primary")
  defaultBrandSecondary      String    @default("#818CF8") @map("default_brand_secondary")
  defaultMaxConnections      String    @default("50") @map("default_max_connections")
  defaultShowAddress         Boolean   @default(true) @map("default_show_address")
  defaultAllowVcard          Boolean   @default(true) @map("default_allow_vcard")
  notifyAttendeeRegister     Boolean   @default(true) @map("notify_attendee_register")
  notifyConnectionMilestone  Boolean   @default(true) @map("notify_connection_milestone")
  notifyAnnouncementDelivery Boolean   @default(false) @map("notify_announcement_delivery")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")
  organiser                  Organiser @relation(fields: [organiserId], references: [id], onDelete: Cascade)

  @@map("organiser_settings")
}

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String   @map("viewer_id")
  viewedId  String   @map("viewed_id")
  eventId   String   @map("event_id")
  source    String   @default("directory")
  createdAt DateTime @default(now()) @map("created_at")

  viewer Attendee @relation("ProfileViewer", fields: [viewerId], references: [id])
  viewed Attendee @relation("ProfileViewed", fields: [viewedId], references: [id])

  @@index([viewedId, createdAt])
  @@index([viewerId, eventId])
  @@index([eventId, createdAt])
  @@map("profile_views")
}

model ConnectionNote {
  id           String   @id @default(cuid())
  authorId     String   @map("author_id")
  connectionId String   @map("connection_id")
  eventId      String   @map("event_id")
  content      String   @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  author Attendee @relation(fields: [authorId], references: [id])

  @@index([authorId, connectionId])
  @@index([eventId])
  @@map("connection_notes")
}

model MatchScore {
  id           String   @id @default(cuid())
  attendeeId   String   @map("attendee_id")
  targetId     String   @map("target_id")
  eventId      String   @map("event_id")
  score        Float
  matchReasons Json     @default("[]") @map("match_reasons")
  computedAt   DateTime @default(now()) @map("computed_at")

  attendee Attendee @relation("MatchSource", fields: [attendeeId], references: [id])
  target   Attendee @relation("MatchTarget", fields: [targetId], references: [id])

  @@unique([attendeeId, targetId])
  @@index([attendeeId, score])
  @@index([eventId, score])
  @@map("match_scores")
}

model Activity {
  id         String   @id @default(cuid())
  attendeeId String   @map("attendee_id")
  eventId    String   @map("event_id")
  type       String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  attendee Attendee @relation(fields: [attendeeId], references: [id])

  @@index([attendeeId, createdAt])
  @@index([eventId, type])
  @@index([createdAt])
  @@map("activities")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketCategory {
  EVENT_ISSUE
  ATTENDEE_ISSUE
  TECHNICAL
  ACCOUNT
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum UserRole {
  SUPER_ADMIN
  ORGANISER
  ATTENDEE
}

enum OrganiserStatus {
  ACTIVE
  SUSPENDED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  DELETED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
}
